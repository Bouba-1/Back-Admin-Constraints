meta {
  name: Créer un projet
  type: http
  seq: 2
}

post {
  url: https://integ.lge-goldeneyes-back.innovation-factory.io/api/project/createProject
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  {
    "name": "Essai QA Sprint 52",
    "description": "Projet créé via Today "
  }
}

tests {
  test("✅ Projet créé ou déjà existant", () => {
    const status = res.getStatus();
    const body = String(res.getBody());
    console.log("Status =", status);
    console.log("Body =", JSON.stringify(body));
    console.log("Type =", typeof body);
  
    if (status === 201) {
      expect(status).to.equal(201);
    } else if (
      status === 400 &&
      body.message === "This project name is already taken"
    ) {
      expect(status).to.equal(400);
    } else {
      throw new Error(
        `Statut inattendu : ${status} - ${body}`
      );
    }
  });
}

settings {
  encodeUrl: true
}
